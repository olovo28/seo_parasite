        <script>
        const advReveal = $('#slot_slider_reveal');
        const aSwipeThreshold = {x: null, y: null};
        const aSwipeStart = {x: null, y: null};

                advReveal.on('keydown', function(ev) {
            if (ev.key === 'ArrowLeft' || ev.key === 'ArrowRight') {
                advReveal.foundation('close');
            }
        });

                advReveal
            .on('touchstart', function(ev) {
                const isLandscape = window.screen.orientation.type.startsWith('landscape');

                aSwipeThreshold.x = Math.round(advReveal.width() / (isLandscape ? 6 : 4));
                aSwipeThreshold.y = Math.round(advReveal.height() / (isLandscape ? 4 : 6));

                aSwipeStart.x = ev.originalEvent.targetTouches.length ? ev.originalEvent.targetTouches[0].pageX : ev.originalEvent.pageX;
                aSwipeStart.y = ev.originalEvent.targetTouches.length ? ev.originalEvent.targetTouches[0].pageY : ev.originalEvent.pageY;
            })
            .on('touchmove', function(ev) {
                const x = ev.originalEvent.targetTouches.length ? ev.originalEvent.targetTouches[0].pageX : ev.originalEvent.pageX;
                const y = ev.originalEvent.targetTouches.length ? ev.originalEvent.targetTouches[0].pageY : ev.originalEvent.pageY;
                const dX = Math.abs(aSwipeStart.x - x);
                const dY = Math.abs(aSwipeStart.y - y);

                if (dX >= aSwipeThreshold.x || dY >= aSwipeThreshold.y) {
                    advReveal.foundation('close');
                }
            })
        ;
    </script>







