# API-токен Dolphin{anty}. Получить: приложение Dolphin -> Настройки -> API (или личный кабинет на сайте).
# Скопируй этот файл в .env и подставь свой токен.
DOLPHIN_API_TOKEN=your_token_here

# (необязательно) Путь к файлу БД SQLite. По умолчанию data/app.db в корне проекта.
# DB_PATH=data/app.db

# Ключи Claude НЕ хранятся здесь — они в БД (управление через `npm run keys`).

# Логин/пароль аккаунта сайта (нужны для публикации, если профиль не залогинен).
# MEINBEZIRK_USER=your_login
# MEINBEZIRK_PASS=your_password

# --- Веб-админка ---
# ADMIN_PASSWORD=задай_пароль_админки
# SESSION_SECRET=длинная_случайная_строка_для_подписи_кук
# PORT=3000

# --- Docker / Dolphin на хосте ---
# В контейнере scheduler/generator укажи хост, где запущен Dolphin{anty}:
# DOLPHIN_HOST=host.docker.internal
# (локально вне Docker не задавать — по умолчанию 127.0.0.1)

# --- Генерация «в рамках тарифа» (подписочный Claude CLI вместо платного API) ---
# Движок генерации по умолчанию: api (платно) | cli (подписка). В UI выбирается у каждой формы.
# CLAUDE_BACKEND=api
# Только для контейнера (задаётся в docker-compose): URL хостового моста к claude CLI.
# На ХОСТЕ НЕ задавать — иначе `npm run generate --backend cli` пойдёт по HTTP вместо прямого спавна.
# CLAUDE_CLI_URL=http://host.docker.internal:3737
# (опц.) общий секрет между мостом и контейнером:
# CLAUDE_BRIDGE_TOKEN=длинная_случайная_строка
# (опц.) порт моста (по умолчанию 3737): CLAUDE_BRIDGE_PORT=3737
# Запуск моста на хосте, где `claude` залогинен в подписку:  npm run claude-bridge
